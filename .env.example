# ─── Harmony Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/harmony

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
LOG_LEVEL=info

# ─── Clerk Authentication ─────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ─── Stripe Payments ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── Cloudflare R2 (Audio Storage) ───────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=harmony-audio

# ─── Solana Blockchain ───────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
EXPO_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
HARMONY_TREASURY_WALLET=YOUR_HARMONY_TREASURY_WALLET_ADDRESS

# ─── Irys / Arweave (NFT Metadata) ──────────────────────────────────────────
IRYS_NODE_URL=https://devnet.irys.xyz

# ─── Mobile API ──────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:4000
